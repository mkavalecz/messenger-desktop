{
  "name": "messenger-desktop",
  "version": "0.4.2",
  "description": "A lightweight desktop wrapper for Facebook Messenger built with Electron.",
  "main": "out/main.js",
  "license": "MIT",
  "homepage": "https://mkavalecz.github.io/messenger-desktop",
  "author": {
    "name": "Máté Kavalecz"
  },
  "scripts": {
    "start": "tsc && concurrently -k \"tsc -w --preserveWatchOutput\" \"electronmon .\"",
    "clean": "rimraf dist out",
    "build": "npm run clean && tsc && electron-builder",
    "build:ci": "npm run clean && tsc && electron-builder --publish never",
    "lint": "eslint --ext .ts,.tsx .",
    "test": "jest"
  },
  "build": {
    "appId": "io.github.mkavalecz.messenger-desktop",
    "productName": "Messenger Desktop",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "icons/**/*",
      "assets/**/*"
    ],
    "win": {
      "icon": "icons/icon.ico",
      "target": "nsis"
    },
    "mac": {
      "icon": "icons/icon.icns",
      "target": "dmg"
    },
    "linux": {
      "icon": "icons/icon.png",
      "target": "AppImage"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.0",
    "concurrently": "^9.2.1",
    "electron": "^40.8.3",
    "electron-builder": "^26.8.2",
    "electronmon": "^2.0.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.6",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.57.1"
  }
}
