{
  "name": "messenger-desktop",
  "version": "0.7.2",
  "description": "A lightweight desktop wrapper for Facebook Messenger built with Electron.",
  "main": "out/main.js",
  "license": "MIT",
  "homepage": "https://mkavalecz.github.io/messenger-desktop",
  "author": {
    "name": "Máté Kavalecz",
    "email": "messenger.desktop@mattwolf.it"
  },
  "scripts": {
    "start": "tsc && concurrently -k \"tsc -w --preserveWatchOutput\" \"electronmon .\"",
    "clean": "rimraf dist out",
    "build": "npm run clean && tsc && electron-builder",
    "build:ci": "npm run clean && tsc && electron-builder --publish never",
    "lint": "eslint --ext .ts,.tsx .",
    "test": "jest"
  },
  "build": {
    "appId": "io.github.mkavalecz.messenger-desktop",
    "productName": "Messenger Desktop",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "icons/**/*",
      "assets/**/*"
    ],
    "win": {
      "icon": "icons/icon.ico",
      "target": "nsis"
    },
    "mac": {
      "icon": "icons/icon.icns",
      "target": "dmg",
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "linux": {
      "icon": "icons/icon.png",
      "target": [
        "deb",
        "rpm"
      ],
      "category": "Network"
    }
  },
  "overrides": {
    "picomatch": "^4.0.4",
    "handlebars": "^4.7.9",
    "@xmldom/xmldom": "^0.8.12",
    "lodash": "^4.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@types/jest": "^29",
    "@types/node": "^24",
    "concurrently": "^9.2.1",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "electronmon": "^2.0.4",
    "eslint": "^9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^17.4.0",
    "jest": "^29",
    "prettier": "^3.8.2",
    "rimraf": "^6.1.3",
    "ts-jest": "^29",
    "typescript": "^6.0",
    "typescript-eslint": "^8.58.1"
  }
}
